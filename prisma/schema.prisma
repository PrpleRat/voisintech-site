generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model QuoteRequest {
  id            String   @id @default(cuid())
  deviceType    String
  problemDesc   String
  name          String
  phone         String
  email         String
  address       String
  city          String
  preferredDays String
  preferredTime String
  preferredDate String?
  scheduledAt DateTime?
  scheduledDurationMinutes Int?
  status        String   @default("new")
  createdAt     DateTime @default(now())
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  message   String
  status    String   @default("new")
  createdAt DateTime @default(now())
}

model Review {
  id        String   @id @default(cuid())
  name      String
  rating    Int
  comment   String
  status    String   @default("pending")
  createdAt DateTime @default(now())
}

model ProRequest {
  id          String   @id @default(cuid())
  serviceType String
  name        String
  phone       String
  email       String
  company     String?
  city        String
  details     String
  status      String   @default("new")
  createdAt   DateTime @default(now())
}

model TradeInPriceCache {
  id              String   @id
  modelId         String
  searchQuery     String
  source          String
  medianResale    Int?
  buybackEstimate Int?
  sampleCount     Int      @default(0)
  rawPrices       String?
  scrapeError     String?
  scrapedAt       DateTime @default(now())
}

model TradeInSyncRun {
  id           String   @id @default(cuid())
  status       String
  modelsTotal  Int
  modelsOk     Int
  modelsFailed Int
  details      String?
  startedAt    DateTime @default(now())
  finishedAt   DateTime?
}

model StoreItem {
  id             String   @id @default(cuid())
  name           String
  description    String   @default("")
  category       String
  buyPriceCents  Int      @default(0)
  sellPriceCents Int
  quantity       Int      @default(0)
  visibleOnStore Boolean  @default(true)
  specs          String?
  imageUrl       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  packItems      StorePackItem[]
}

model StorePack {
  id             String   @id @default(cuid())
  name           String
  description    String   @default("")
  sellPriceCents Int
  visibleOnStore Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  items          StorePackItem[]
}

model StorePackItem {
  id       String    @id @default(cuid())
  packId   String
  itemId   String
  quantity Int       @default(1)
  pack     StorePack @relation(fields: [packId], references: [id], onDelete: Cascade)
  item     StoreItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([packId, itemId])
}
