generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model QuoteRequest {
  id            String   @id @default(cuid())
  deviceType    String
  problemDesc   String
  name          String
  phone         String
  email         String
  address       String
  city          String
  preferredDays String
  preferredTime String
  preferredDate String?
  scheduledAt DateTime?
  scheduledDurationMinutes Int?
  status        String   @default("new")
  createdAt     DateTime @default(now())
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  message   String
  status    String   @default("new")
  createdAt DateTime @default(now())
}

model Review {
  id        String   @id @default(cuid())
  name      String
  rating    Int
  comment   String
  status    String   @default("pending")
  createdAt DateTime @default(now())
}

model ProRequest {
  id          String   @id @default(cuid())
  serviceType String
  name        String
  phone       String
  email       String
  company     String?
  city        String
  details     String
  status      String   @default("new")
  createdAt   DateTime @default(now())
}
