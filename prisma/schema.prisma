generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model QuoteRequest {
  id            String   @id @default(cuid())
  deviceType    String
  problemDesc   String
  name          String
  phone         String
  email         String
  address       String
  city          String
  preferredDays String
  preferredTime String
  preferredDate String?
  scheduledAt DateTime?
  scheduledDurationMinutes Int?
  status        String   @default("new")
  createdAt     DateTime @default(now())
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  message   String
  status    String   @default("new")
  createdAt DateTime @default(now())
}

model Review {
  id        String   @id @default(cuid())
  name      String
  rating    Int
  comment   String
  status    String   @default("pending")
  createdAt DateTime @default(now())
}

model ProRequest {
  id          String   @id @default(cuid())
  serviceType String
  name        String
  phone       String
  email       String
  company     String?
  city        String
  details     String
  status      String   @default("new")
  createdAt   DateTime @default(now())
}

model TradeInPriceCache {
  id              String   @id
  modelId         String
  searchQuery     String
  source          String
  medianResale    Int?
  buybackEstimate Int?
  sampleCount     Int      @default(0)
  rawPrices       String?
  scrapeError     String?
  scrapedAt       DateTime @default(now())
}

model TradeInSyncRun {
  id           String   @id @default(cuid())
  status       String
  modelsTotal  Int
  modelsOk     Int
  modelsFailed Int
  details      String?
  startedAt    DateTime @default(now())
  finishedAt   DateTime?
}

model StoreItem {
  id             String   @id @default(cuid())
  name           String
  description    String   @default("")
  category       String
  buyPriceCents  Int      @default(0)
  sellPriceCents Int
  quantity       Int      @default(0)
  visibleOnStore Boolean  @default(true)
  specs          String?
  imageUrl       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  packItems      StorePackItem[]
}

model StorePack {
  id             String   @id @default(cuid())
  name           String
  description    String   @default("")
  sellPriceCents Int
  visibleOnStore Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  items          StorePackItem[]
}

model StorePackItem {
  id       String    @id @default(cuid())
  packId   String
  itemId   String
  quantity Int       @default(1)
  pack     StorePack @relation(fields: [packId], references: [id], onDelete: Cascade)
  item     StoreItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([packId, itemId])
}

// ─── Train Suite (apps iOS + sync cloud) ─────────────────────────────────────

model SuiteAccount {
  id            String              @id @default(cuid())
  email         String              @unique
  passwordHash  String
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  memberships   SuiteMembership[]
  refreshTokens SuiteRefreshToken[]
}

model SuiteWorkspace {
  id              String               @id @default(cuid())
  name            String
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  memberships     SuiteMembership[]
  apiKeys         SuiteApiKey[]
  businessProfile SuiteBusinessProfile?
  clients         SuiteClient[]
  serviceTypes    SuiteServiceType[]
  businessRecords SuiteBusinessRecord[]
}

model SuiteMembership {
  id          String         @id @default(cuid())
  accountId   String
  workspaceId String
  role        String         @default("owner")
  createdAt   DateTime       @default(now())
  account     SuiteAccount   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  workspace   SuiteWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([accountId, workspaceId])
}

model SuiteBusinessProfile {
  id           String         @id @default(cuid())
  workspaceId  String         @unique
  businessName String         @default("")
  ownerName    String         @default("")
  address      String         @default("")
  phone        String         @default("")
  email        String         @default("")
  siret        String         @default("")
  updatedAt    DateTime       @updatedAt
  workspace    SuiteWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model SuiteClient {
  id          String         @id @default(cuid())
  workspaceId String
  externalId  String?
  name        String
  companyName String         @default("")
  email       String         @default("")
  phone       String         @default("")
  address     String         @default("")
  notes       String         @default("")
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  deletedAt   DateTime?
  workspace   SuiteWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, externalId])
  @@index([workspaceId, updatedAt])
}

model SuiteApiKey {
  id          String         @id @default(cuid())
  workspaceId String
  name        String         @default("default")
  keyPrefix   String
  keyHash     String
  createdAt   DateTime       @default(now())
  lastUsedAt  DateTime?
  revokedAt   DateTime?
  workspace   SuiteWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([keyHash])
}

model SuiteServiceType {
  id                     String         @id @default(cuid())
  workspaceId            String
  name                   String
  defaultDurationMinutes Int            @default(60)
  defaultPriceCents      Int            @default(0)
  sortOrder              Int            @default(0)
  matchDeviceTypes       String         @default("[]")
  matchKeywords          String         @default("[]")
  quoteRole              String         @default("")
  isActive               Boolean        @default(true)
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  workspace              SuiteWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, name])
  @@index([workspaceId, sortOrder])
}

model SuiteBusinessRecord {
  id          String         @id @default(cuid())
  workspaceId String
  kind        String
  source      String
  externalId  String
  payload     String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  deletedAt   DateTime?
  workspace   SuiteWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, kind, externalId])
  @@index([workspaceId, kind, updatedAt])
}

model SuiteRefreshToken {
  id        String       @id @default(cuid())
  accountId String
  tokenHash String       @unique
  expiresAt DateTime
  createdAt DateTime     @default(now())
  account   SuiteAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model SuiteBetaSignup {
  id             String   @id @default(cuid())
  name           String
  email          String
  phone          String   @default("")
  activity       String   @default("")
  appsInterested String   @default("[]")
  message        String   @default("")
  status         String   @default("new")
  createdAt      DateTime @default(now())

  @@index([email])
  @@index([status, createdAt])
}
