DATABASE_URL="file:./dev.db"
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your_turso_token
RESEND_API_KEY=your_key_here
NOTIFICATION_EMAIL=voisintech3@gmail.com
FROM_EMAIL=contact@voisintech.fr
REPLY_TO_EMAIL=voisintech3@gmail.com
ADMIN_PASSWORD=changeme123

# Train Suite API (apps iOS + sync cloud)
# Généré automatiquement par: npm run suite:setup
SUITE_JWT_SECRET=change-me-run-npm-run-suite-setup

# Clé API workspace (optionnel si TRAIN_SUITE_WORKSPACE_ID est défini ou compte cloud déjà en base)
TRAIN_SUITE_API_KEY=
# Id workspace (recommandé sur Vercel — visible dans l'admin après 1ère connexion FactuTrain)
TRAIN_SUITE_WORKSPACE_ID=

# Sync quotidien prix reprise (GitHub Action → ingest API)
CRON_SECRET=change-me-long-random-string
SITE_URL=https://www.voisintech.fr
# Clé gratuite https://www.scraperapi.com — contourne anti-bot LBC/BM (15 modèles/jour ≈ 900 crédits/mois)
SCRAPER_API_KEY=

# Google Analytics 4 (obligatoire en prod Vercel)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Liens publics TestFlight (beta iOS Voisin Suite — admin dashboard)
TESTFLIGHT_URL_AGENDA=
TESTFLIGHT_URL_FACTURE=
TESTFLIGHT_URL_COMPTA=
TESTFLIGHT_URL_CLIENTS=

# Obligatoire pour envoyer aux clients ET à voisintech3@gmail.com
# Google → Sécurité → Validation 2 étapes → Mots de passe des applications
GMAIL_USER=voisintech3@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
